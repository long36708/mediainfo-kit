{
  "name": "mediainfo-kit",
  "version": "0.2.0",
  "description": "A utility toolkit for mediainfo.js with multi-source support and formatters",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "playground": "pnpm -F playground dev",
    "prepublishOnly": "npm run build && npm run test"
  },
  "workspaces": [
    "playground"
  ],
  "keywords": [
    "mediainfo",
    "video",
    "audio",
    "metadata",
    "media-info",
    "wasm"
  ],
  "author": "longmo",
  "license": "MIT",
  "peerDependencies": {
    "mediainfo.js": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "jsdom": "^29.0.1",
    "mediainfo.js": "^0.3.7",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/long36708/mediainfo-kit.git"
  }
}
